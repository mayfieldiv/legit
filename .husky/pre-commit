#!/bin/sh

# Save unstaged changes so checks run against exactly what's being committed.
# Uses a patch file instead of git stash --keep-index (which conflicts on pop).
UNSTAGED_PATCH=$(mktemp)
HAS_UNSTAGED=0
if ! git diff --quiet; then
	git diff > "$UNSTAGED_PATCH"
	git checkout -- .
	HAS_UNSTAGED=1
fi

restore_unstaged() {
	if [ "$HAS_UNSTAGED" -eq 1 ]; then
		if ! git apply "$UNSTAGED_PATCH" 2>/dev/null; then
			if ! git apply --3way "$UNSTAGED_PATCH" 2>/dev/null; then
				echo "⚠️  Could not restore unstaged changes. Patch saved at: $UNSTAGED_PATCH"
				return
			fi
		fi
	fi
	rm -f "$UNSTAGED_PATCH"
}

echo "Running formatting, linting, and type checking..."
bun run check
if [ $? -ne 0 ]; then
	echo "Checks failed. Please fix the errors before committing."
	restore_unstaged
	exit 1
fi

git diff --cached --name-only -z | while IFS= read -r -d '' file; do
	if [ -f "$file" ]; then
		git add "$file"
	fi
done

restore_unstaged

echo "All pre-commit checks passed."
