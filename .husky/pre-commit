#!/bin/sh

STAGED_FILES=$(git diff --cached --name-only)

# Save unstaged changes so checks run against exactly what's being committed.
# Uses a patch file instead of git stash --keep-index (which conflicts on pop).
UNSTAGED_PATCH=$(mktemp)
HAS_UNSTAGED=0
if ! git diff --quiet; then
	git diff > "$UNSTAGED_PATCH"
	git checkout -- .
	HAS_UNSTAGED=1
fi

restore_unstaged() {
	if [ "$HAS_UNSTAGED" -eq 1 ]; then
		git apply "$UNSTAGED_PATCH" 2>/dev/null || true
		rm -f "$UNSTAGED_PATCH"
	else
		rm -f "$UNSTAGED_PATCH"
	fi
}

echo "Running formatting, linting, and type checking..."
bun run check
if [ $? -ne 0 ]; then
	echo "Checks failed. Please fix the errors before committing."
	restore_unstaged
	exit 1
fi

for file in $STAGED_FILES; do
	if [ -f "$file" ]; then
		git add "$file"
	fi
done

restore_unstaged

echo "All pre-commit checks passed."
