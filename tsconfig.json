{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@tsconfig/bun/tsconfig.json",
  "compilerOptions": {
    "jsx": "preserve",
    "jsxImportSource": "@opentui/solid",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "types": ["bun-types"]
  },
  "exclude": [
    "vendor/opentui-solid2/examples",
    "vendor/opentui-solid2/tests",
    "vendor/opentui-solid2/src/plugins",
    "vendor/opentui-solid2/src/elements/extras.ts",
    "vendor/opentui-solid2/scripts/runtime-plugin-support.ts",
    "node_modules/@opentui/solid/examples",
    "node_modules/@opentui/solid/tests",
    "node_modules/@opentui/solid/src/plugins",
    "node_modules/@opentui/solid/src/elements/extras.ts",
    "node_modules/@opentui/solid/scripts/runtime-plugin-support.ts"
  ]
}
