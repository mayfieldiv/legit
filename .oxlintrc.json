{
  "plugins": ["typescript"],
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "pedantic": "off",
    "style": "off",
    "nursery": "off"
  },
  "rules": {
    "typescript/no-explicit-any": "warn"
  },
  "overrides": [
    {
      "files": ["tests/**"],
      "rules": {
        "typescript/no-explicit-any": "off"
      }
    }
  ],
  "settings": {
    "react": {
      "formComponents": [],
      "linkComponents": [],
      "version": null,
      "componentWrapperFunctions": []
    }
  },
  "env": {
    "builtin": true
  },
  "globals": {},
  "ignorePatterns": [".tmp", "vendor/solid-js-browser"]
}
